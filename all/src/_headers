# Cloudflare Pages headers
# Assets are versioned in HTML, so browsers can keep them for a long time.
# HTML still revalidates in the browser, while CDN caches can absorb repeat edge traffic.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/image/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Cloudflare Pages 把 *.html 规范化为无后缀地址，缓存策略与 *.html 保持一致
