# Cloudflare Pages headers
# JS/CSS file names are stable, so browsers must revalidate them after each deploy.
# Images can keep a long cache because they do not control site behavior.

/assets/*
  Cache-Control: public, max-age=0, must-revalidate

/image/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/search-index.json
  Cache-Control: public, max-age=0, must-revalidate
